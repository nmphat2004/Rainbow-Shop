# Server Port
PORT=5000

# Database Configuration (MongoDB Atlas or Local Connection URI)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/rainbow?retryWrites=true&w=majority

# JWT Token Secret Key
JWT_SECRET=your_jwt_secret_key_here

# Cloudinary Credentials (For Product Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google Gemini API Key (For AI Shopping Chatbot Assistant)
GEMINI_API_KEY="your_google_gemini_api_key_here"
